{# Header del panel de filtros — MakerBundle Design System.
   Hooks de JS (app-bundle.js): #filters-btn-mostrar (texto reemplazado por .html()),
   .navbarAlert (se muestra quitando d-none si hay filtros activos),
   #reset-filters (dispara el botón reset dentro de #filtros). #}
<div class="mb-card__header">
    <span class="navbarAlert mb-badge mb-badge--warning d-none">
        <span class="fa fa-filter" aria-hidden="true"></span>
        Filtro activado
        <a href="#" id="reset-filters" title="Quitar filtros" aria-label="Quitar filtros" class="mb-chip__close">
            <span class="fa fa-times" aria-hidden="true"></span>
        </a>
    </span>

    <button type="button" id="filters-btn-mostrar" class="mb-btn-outline ms-auto"
            data-bs-toggle="collapse" data-bs-target="#filters"
            aria-expanded="false" aria-controls="filters">
        Mostrar filtros
    </button>
</div>
